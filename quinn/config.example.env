# Application-layer proxy (mitmproxy)
# Listen on all interfaces so VPN clients can reach the proxy.
PROXY_LISTEN_HOST=0.0.0.0
PROXY_LISTEN_PORT=8080
# Set to "web", "proxy", "dump", or "transparent" (requires redirect rules on server).
PROXY_MODE=web

# Packet-level filter (nftables on wg0)
# Drop inner packets larger than this (bytes). Set to 0 to disable.
# Typical MTU is 1500; use something above MTU to only drop jumbos or leave default.
PACKET_MAX_BYTES=0
# WireGuard interface name on the server.
WG_INTERFACE=wg0
# VPN client subnet for transparent redirect (e.g. 10.0.0.0/24). Only needed for transparent mode.
# VPN_SUBNET=
