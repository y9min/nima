# Application-layer proxy (mitmproxy)
# Listen on all interfaces so VPN clients can reach the proxy.
PROXY_LISTEN_HOST=0.0.0.0
PROXY_LISTEN_PORT=8080
# Set to "web", "proxy", "dump", or "transparent" (requires redirect rules on server).
PROXY_MODE=web

# Packet-level filter (nftables on wg0)
# Drop inner packets larger than this (bytes). Set to 0 to disable.
# Typical MTU is 1500; use something above MTU to only drop jumbos or leave default.
PACKET_MAX_BYTES=0
# WireGuard interface name on the server.
WG_INTERFACE=wg0
# VPN client subnet for transparent redirect (e.g. 10.0.0.0/24). Only needed for transparent mode.
# VPN_SUBNET=

# --- Option A: Certificate-free connection byte limit (setup_connbyte_filter.sh) ---
# RST any single HTTPS connection through the VPN exceeding this many bytes.
# No CA cert needed on devices. Blocks video reels but also any large single-connection
# download. 2000000 (2 MB) is a good default; raise for more permissive, lower to block
# more aggressively.
# CONN_MAX_BYTES=2000000

# --- Option B: MITM proxy video blocking (setup_transparent_redirect.sh + run_proxy.sh) ---
# Max video response size (bytes) from Instagram before blocking.
# Requires CA cert on devices. More precise (content-type aware) but more setup.
# REELS_VIDEO_MAX_BYTES=500000

# --- Analytics / Flow Logger ---
# Supabase project URL and service role key for server-side traffic logging.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Flush buffered events every N seconds (default 10).
# ANALYTICS_FLUSH_INTERVAL=10
# Flush when buffer reaches N events (default 50).
# ANALYTICS_FLUSH_SIZE=50
